<!DOCTYPE html>
<html>
<head>
    <title>Add Expense</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>Add Expense</h1>

    <form action="/add" method="POST">
        <input type="text" name="title" placeholder="Title" required><br><br>
        <input type="number" name="amount" placeholder="Amount" required><br><br>
        <input type="number" name="members" placeholder="number of members"required><br><br>
        <input type="text" name="category" placeholder="Category" required><br><br>
        

        <button type="submit">Add Expense</button>
    </form>
</body>
</html>
<!DOCTYPE html>
<html>
<head>
<title>Edit Trip</title>
<link rel="stylesheet" href="/style.css">
</head>

<body>

<h1>Edit Trip</h1>

<form action="/trip/edit/<%= trip._id %>" method="POST">

<input 
type="text" 
name="tripName" 
value="<%= trip.tripName %>" 
required>

<br><br>

<input 
type="number" 
name="members" 
value="<%= trip.members %>" 
required>

<br><br>

<button type="submit">Update Trip</button>

</form>

</body>
</html>